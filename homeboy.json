{
  "auto_cleanup": false,
  "changelog_target": "docs/CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "extrachill-events",
  "remote_path": "wp-content/plugins/extrachill-events",
  "version_targets": [
    {
      "file": "extrachill-events.php",
      "pattern": "(?m)^\\s*\\*?\\s*Version:\\s*([0-9.]+)"
    },
    {
      "file": "extrachill-events.php",
      "pattern": "EXTRACHILL_EVENTS_VERSION',\\s*'([0-9.]+)'"
    },
    {
      "file": "blocks/concert-stats/block.json",
      "pattern": "\"version\":\\s*\"([0-9.]+)\"",
      "artifact_path": "build/concert-stats/block.json"
    },
    {
      "file": "blocks/event-submission/block.json",
      "pattern": "\"version\":\\s*\"([0-9.]+)\"",
      "artifact_path": "build/event-submission/block.json"
    }
  ]
}